            "std": [58.395, 57.12, 57.375]
          }
        ],
        "postprocessing": [
          {
            "type": "Softmax",
            "dim": 1
          },
          {
            "type": "TopK",
            "k": 5
          }
        ],
        "files": ["resnet50-v2-7.onnx"],
        "metadata": {
          "input_shape": [1, 3, 224, 224],
          "output_shape": [1, 1000],
          "opset_version": 7,
          "task": "image_classification",
          "num_classes": 1000,
          "dataset": "ImageNet",
          "accuracy": {
            "top1": 0.7581,
            "top5": 0.9282
          }
        }
      }
