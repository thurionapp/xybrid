        "execution_template": {
          "type": "SimpleMode",
          "model_file": "resnet50-v2-7.onnx"
        },
        "preprocessing": [
          {
            "type": "Reshape",
            "shape": [1, 3, 256, 256]
          },
          {
            "type": "CenterCrop",
