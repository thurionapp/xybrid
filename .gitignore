# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo.lock - commit for binary crates, ignore for libraries
# Since this is a workspace with both, we commit it
# Cargo.lock

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Debug files
*.dSYM/
*.su
*.idb

# Rust-analyzer
rust-project.json

# Backup files
*.bak
*.orig

# Environment files
.env
.env.local

# Test artifacts
*.log

*.wav

# Xcode user data
xcuserdata/
*.xcuserstate
*.xcworkspacedata

# SwiftPM user data
.swiftpm/xcode/xcuserdata/

# SwiftPM build output (root Package.swift)
/.build/
Package.resolved

# Build artifacts - XCFrameworks (built by `cargo xtask build-xcframework`)
bindings/apple/XCFrameworks/*.xcframework/
# Python bytecode
__pycache__/
*.pyc

# CycloneDX SBOMs — generated by `cargo cyclonedx` and attached to releases
# in CI; never committed (they go stale and bloat the repo).
*.cdx.json
